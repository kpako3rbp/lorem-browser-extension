{
  "manifest_version": 3,
  "name": "Lorem Extension",
  "version": "1.0.0",
  "description": "Insert lorem text into inputs and textareas",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "src/background.ts"
  },
  "action": {
    "default_title": "Lorem Extension",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ]
}
